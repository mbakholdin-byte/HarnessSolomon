# Solomon Harness — переменные окружения
# Скопируйте в .env и заполните
# НИКОГДА не коммитьте .env в git (см. .gitignore)

# === Фаза 0: LLM Providers (только облачные) ===
# Primary
MINIMAX_API_KEY=

# Optional
ZHIPUAI_API_KEY=
MOONSHOT_API_KEY=

# === Harness ===
HARNESS_LOG_LEVEL=INFO
HARNESS_PROJECT_ROOT=C:/MyAI
HARNESS_SESSION_DIR=./data/sessions
HARNESS_DB_PATH=./data/harness.db
HARNESS_HOST=0.0.0.0
HARNESS_PORT=8000

# === Frontend (Vite dev) ===
VITE_API_BASE=http://localhost:8000
VITE_WS_BASE=ws://localhost:8000

# === Фаза 0.5: локальные модели (Ollama) ===
OLLAMA_HOST=http://127.0.0.1:11434

# === Фаза 1: Memory (Qdrant, Neo4j) ===
QDRANT_HOST=127.0.0.1
QDRANT_PORT=7333
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
